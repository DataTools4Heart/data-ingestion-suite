        "jsonClass" : "FileSystemSource",
        "path" : "Echocardiography.parquet",
        "contentType" : "parquet",
        "options" : {
          "distinct" : "true"
        },
        "preprocessSql" : "select studyId_0919, identifier_value, effectiveDateTime, array_agg(Value) as Value, array_agg(UnitName) as UnitName, array_agg(LOINCcode) as LOINCcode, array_agg(LOINCdisplay) as LOINCdisplay, count(*) as count\nfrom source \ngroup by studyId_0919, identifier_value, effectiveDateTime",
        "sourceRef" : "umcu-source"
      },
