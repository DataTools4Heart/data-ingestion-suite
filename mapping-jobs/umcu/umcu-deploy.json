  }, {
    "name" : "condition-mapping",
    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/umcu/condition-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "Conditions.parquet",
        "contentType" : "parquet",
        "options" : {
