    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/umcu/ecg-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "ECG.parquet",
        "contentType" : "parquet",
        "options" : {
          "distinct" : "true"
        },
        "preprocessSql" : "select studyId_0919, ECGTestID, AcquisitionDateTime, \narray_agg(ValueQuantity) as ValueQuantity, \narray_agg(LOINCcode) as LOINCcode, \narray_agg(LOINCdisplay) as LOINCdisplay, \narray_agg(Units) as Units,\ncount(*) as count\nfrom source \ngroup by studyId_0919, ECGTestID, AcquisitionDateTime",
        "sourceRef" : "umcu-source"
      },
      "encounters" : {
        "jsonClass" : "FileSystemSource",
        "path" : "Encounters.parquet",
