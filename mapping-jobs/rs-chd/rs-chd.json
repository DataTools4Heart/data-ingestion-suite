    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/rs-chd/encounter-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "nbhw/VisitHospitalization.txt",
        "contentType" : "tsv",
        "options" : { },
        "sourceRef" : "rs-source"
      }
    }
  }, {
    "name" : "ecg-mapping",
    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/rs-chd/ecg-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "chd/ECG.txt",
        "contentType" : "tsv",
        "options" : {
          "distinct" : "true"
        },
        "preprocessSql" : "select count(*) as count, subject, effectiveDateTime,\r\narray_agg(category) as category,\r\narray_agg(code) as code,\r\narray_agg(component) as component,\r\narray_agg(value) as value\r\nfrom source \r\nwhere component IS NOT NULL\r\ngroup by subject, effectiveDateTime",
        "sourceRef" : "rs-source"
      },
      "encounters" : {
        "jsonClass" : "FileSystemSource",
        "path" : "nbhw/VisitHospitalization.txt",
        "contentType" : "tsv",
        "options" : { },
        "sourceRef" : "rs-source"
      }
    }
  }, {
    "name" : "condition-mapping",
    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/rs-chd/condition-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "chd/Condition.txt",
        "contentType" : "tsv",
        "options" : {
          "inferSchema" : "false"
        },
        "preprocessSql" : "select * from source where year(onsetDateTime) > $yearMin and year(onsetDateTime) < $yearMax",
        "sourceRef" : "rs-source"
      },
      "encounters" : {
        "jsonClass" : "FileSystemSource",
        "path" : "nbhw/VisitHospitalization.txt",
        "contentType" : "tsv",
        "options" : { },
        "sourceRef" : "rs-source"
      }
    },
    "batchingStrategy" : {
      "batchParameterSets" : [ {
        "yearMin" : "2000",
        "yearMax" : "2018"
      }, {
        "yearMin" : "2017",
        "yearMax" : "2030"
      } ]
    }
  }, {
    "name" : "medication-mapping",
    "mappingRef" : "https://datatools4heart.eu/fhir/mappings/rs-chd/medication-mapping",
    "sourceBinding" : {
      "source" : {
        "jsonClass" : "FileSystemSource",
        "path" : "chd/MED_ORDERS_DRUGS.txt",
        "contentType" : "tsv",
        "options" : {
