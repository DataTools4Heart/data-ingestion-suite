        "path" : "chd/VitalSign.txt",
        "contentType" : "tsv",
        "options" : {
          "distinct" : "true",
          "inferSchema" : "false"
        },
        "preprocessSql" : "SELECT *\r\nFROM source\r\nWHERE YEAR(effectiveDateTime) = $year",
        "sourceRef" : "rs-source"
      },
      "encounters" : {
