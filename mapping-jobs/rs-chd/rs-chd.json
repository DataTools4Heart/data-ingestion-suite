  "id" : "rs-chd",
  "name" : "rs-chd",
  "description" : "For CHD hospitals (4 different hospitals) in Stockholm, Sweden",
  "sourceSettings" : {
    "rs-source" : {
      "jsonClass" : "FileSystemSourceSettings",
      "name" : "rs-source",
