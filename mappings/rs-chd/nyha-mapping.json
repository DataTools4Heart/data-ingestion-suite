{
  "id" : "nyha-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/rs-chd/nyha-mapping",
  "name" : "nyha-mapping",
  "title" : "NYHAAssessment table mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-chd/NYHA",
    "joinOn" : [ "subject" ]
  }, {
    "alias" : "encounters",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-chd/Encounter",
    "joinOn" : [ "subject" ]
  } ],
  "context" : { },
  "variable" : [ {
    "name" : "effectiveDate",
    "language" : "text/fhirpath",
    "expression" : "effectiveDateTime.substring(0, 10).utl:toFhirDateTime('yyyy-MM-dd')"
  }, {
    "name" : "relatedEncounter",
    "language" : "text/fhirpath",
    "expression" : " %encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate)).first() "
  }, {
    "name" : "relatedEncounterSecondary",
    "language" : "text/fhirpath",
    "expression" : " iif(%relatedEncounter.empty(), %encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate))).first()  "
  } ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Observation', 'chd-nyha' & subject.toString() & effectiveDateTime.toString() & value.toString())}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-NYHAAssessment" ]
        },
        "resourceType" : "Observation",
        "category" : [ {
          "coding" : [ {
            "system" : "http://terminology.hl7.org/CodeSystem/observation-category",
            "code" : "exam",
            "display" : "Exam"
          } ]
        } ],
        "code" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "88020-3",
            "display" : "Functional capacity NYHA",
            "@sliceName" : "loincCode"
          } ]
        },
        "effectiveDateTime" : "{{effectiveDateTime.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss')}}",
        "valueCodeableConcept" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "{{value}}"
          } ]
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', subject.toString())}}",
        "encounter" : "{{? iif(%relatedEncounter.exists(), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounter.id), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounterSecondary.id) )}}",
        "identifier" : [ {
          "value" : "{{subject.toString() & '-' & effectiveDateTime.toString() & '-' & value.toString()}}"
        } ],
        "status" : "final"
      }
    }
  } ]
}