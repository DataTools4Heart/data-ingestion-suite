{
  "id" : "medication-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/gem/medication-mapping",
  "name" : "medication-mapping",
  "title" : "Mapping of GEM's farmaci table to DT4H Medication Administered FHIR profile",
  "isDraft" : false,
  "source" : [ {
    "alias" : "medications",
    "url" : "https://datatools4heart.eu/fhir/schemas/gem/medication",
    "joinOn" : [ "codice_sanitario" ]
  }, {
    "alias" : "encounters",
    "url" : "https://datatools4heart.eu/fhir/schemas/gem/encounter",
    "joinOn" : [ "codice_sanitario" ]
  } ],
  "context" : { },
  "variable" : [ {
    "name" : "relatedEncounter",
    "language" : "text/fhirpath",
    "expression" : "%encounters.where(DATA_IN.toDate() <= %context.date.toDate() and DATA_OUT.toDate() >= %context.date.toDate()).first()"
  } ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Medication', CODICE_SANITARIO.toString() & date.toString() & medication_name & medication_component & ATC)}}",
        "meta" : {
          "source" : "{{%sourceSystem.sourceUri}}",
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-MedicationRequest" ]
        },
        "resourceType" : "MedicationRequest",
        "medication" : {
          "concept" : {
            "coding" : [ {
              "system" : "http://www.whocc.no/atc",
              "code" : "{{ATC}}",
              "display" : "{{? medication_name}}",
              "@sliceName" : "atcCode"
            } ],
            "text" : "{{ medication_name & ' - ' & medication_component}}"
          }
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', CODICE_SANITARIO.toString())}}",
        "encounter" : "{{? mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounter.NOSOGRAFICO.nav:orElse(%relatedEncounter.NUM_PS))}}",
        "identifier" : [ {
          "value" : "{{CODICE_SANITARIO.toString() & '-' & date.toString() & '-' & medication_name & '-' & medication_component & '-' & ATC}}"
        } ],
        "status" : "completed",
        "intent" : "order",
        "authoredOn" : "{{date}}",
        "dosageInstruction" : [ {
          "timing" : {
            "repeat" : {
              "frequency" : "{{? frequency}}",
              "period" : "{{? period}}",
              "periodUnit" : "{{? periodUnit}}"
            }
          },
          "doseAndRate" : [ {
            "doseQuantity" : {
              "value" : "{{? dose}}",
              "unit" : "{{? doseUnit}}"
            }
          } ]
        } ]
      }
    }
  } ]
}