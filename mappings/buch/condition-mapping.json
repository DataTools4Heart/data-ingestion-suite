{
  "id" : "condition-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/buch/condition-mapping",
  "name" : "condition-mapping",
  "title" : "Condition Mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/buch/Condition",
    "joinOn" : [ ]
  } ],
  "context" : { },
  "variable" : [ ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Condition', patient_id & admission_id & icd_code & admission_date.toString())}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-Condition" ]
        },
        "resourceType" : "Condition",
        "code" : {
          "coding" : [ {
            "code" : "{{icd_code}}",
            "system" : "http://hl7.org/fhir/sid/icd-10",
            "@sliceName" : "icd10Code"
          } ]
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', patient_id)}}",
        "encounter" : "{{mpp:createFhirReferenceWithHashedId('Encounter', admission_id)}}",
        "onsetDateTime" : "{{admission_date}}",
        "identifier" : [ {
          "value" : "{{patient_id & '-' & admission_id & '-' & icd_code & '-' & admission_date.toString()}}"
        } ],
        "clinicalStatus" : {
          "coding" : [ {
            "code" : "active"
          } ]
        },
        "category" : [ {
          "coding" : [ {
            "code" : "encounter-diagnosis",
            "system" : "http://terminology.hl7.org/CodeSystem/condition-category",
            "display" : "Encounter Diagnosis"
          } ]
        } ]
      }
    }
  } ]
}