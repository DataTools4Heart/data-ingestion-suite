{
  "id" : "nyha-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/buch/nyha-mapping",
  "name" : "nyha-mapping",
  "title" : "NYHA mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/buch/NYHA",
    "joinOn" : [ ]
  } ],
  "context" : {
    "nyhaMappings" : {
      "category" : "concept-map",
      "url" : "$CONTEXT_REPO/buch/nyha-mappings.csv"
    }
  },
  "variable" : [ ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Observation', 'nyha' & admission_id & patient_id & admission_date.toString() & entity)}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-NYHAAssessment" ]
        },
        "resourceType" : "Observation",
        "category" : [ {
          "coding" : [ {
            "system" : "http://terminology.hl7.org/CodeSystem/observation-category",
            "code" : "exam",
            "display" : "Exam"
          } ]
        } ],
        "code" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "88020-3",
            "display" : "Functional capacity NYHA",
            "@sliceName" : "loincCode"
          } ]
        },
        "effectiveDateTime" : "{{admission_date}}",
        "valueCodeableConcept" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "{{mpp:getConcept(%nyhaMappings, value.nav:orElse(unit), 'target_code')}}"
          } ]
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', patient_id)}}",
        "encounter" : "{{mpp:createFhirReferenceWithHashedId('Encounter', admission_id)}}",
        "identifier" : [ {
          "value" : "{{admission_id & '-' & patient_id & '-' & admission_date.toString() & '-' & entity}}"
        } ],
        "status" : "final"
      }
    }
  } ]
}