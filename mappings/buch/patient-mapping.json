{
  "id" : "patient-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/buch/patient-mapping",
  "name" : "patient-mapping",
  "title" : "Patient mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/buch/Patient",
    "joinOn" : [ ]
  } ],
  "context" : { },
  "variable" : [ ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Patient', patient_id)}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-Patient" ]
        },
        "resourceType" : "Patient",
        "gender" : "{{iif(sex = 'Male', 'male', 'female')}}",
        "birthDate" : "{{birth_date}}",
        "deceasedDateTime" : "{{? decease_date.utl:toFhirDateTime('dd/MM/yyyy' | 'dd.MM.yyyy')}}",
        "identifier" : [ {
          "value" : "{{patient_id}}"
        } ]
      }
    }
  }, {
    "precondition" : {
      "name" : "deceased",
      "language" : "text/fhirpath",
      "expression" : "decease_date.exists()"
    },
    "expression" : {
      "name" : "death",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Observation', 'death' & patient_id & admission_date)}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-CauseOfDeath" ]
        },
        "resourceType" : "Observation",
        "status" : "final",
        "category" : [ {
          "coding" : [ {
            "system" : "http://terminology.hl7.org/CodeSystem/observation-category",
            "code" : "exam",
            "display" : "Exam"
          } ]
        } ],
        "code" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "79378-6",
            "display" : "Cause of death",
            "@sliceName" : "loincCode"
          } ]
        },
        "effectiveDateTime" : "{{decease_date.utl:toFhirDateTime('dd/MM/yyyy' | 'dd.MM.yyyy')}}",
        "valueCodeableConcept" : {
          "coding" : [ {
            "system" : "http://hl7.org/fhir/sid/icd-10",
            "code" : "R99"
          } ]
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', patient_id)}}",
        "identifier" : [ {
          "value" : "{{patient_id & '-' & admission_date}}"
        } ]
      }
    }
  } ]
}