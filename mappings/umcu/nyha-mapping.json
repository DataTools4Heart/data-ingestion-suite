{
  "id" : "nyha-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/umcu/nyha-mapping",
  "name" : "nyha-mapping",
  "title" : "Mapping of UMCU's NYHA table to HFR-NYHAAssessment FHIR profile",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/umcu/NYHA",
    "joinOn" : [ "studyId_0919" ]
  }, {
    "alias" : "encounters",
    "url" : "https://datatools4heart.eu/fhir/schemas/umcu/Encounter",
    "joinOn" : [ "studyId_0919" ]
  } ],
  "context" : {
    "nyhaConceptMap" : {
      "category" : "concept-map",
      "url" : "$CONTEXT_REPO/umcu/nyha-map.csv"
    }
  },
  "variable" : [ {
    "name" : "relatedEncounter",
    "language" : "text/fhirpath",
    "expression" : " %encounters.where(period_start.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss') <= %context.effectivedate.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss' | 'yyyy-MM-dd') and period_end.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss') >= %context.effectivedate.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss' | 'yyyy-MM-dd')).first() "
  } ],
  "mapping" : [ {
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Observation', studyId_0919.toString() & NYHA_class & effectivedate.toString())}}",
        "meta" : {
          "source" : "{{%sourceSystem.sourceUri}}",
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-NYHAAssessment" ]
        },
        "resourceType" : "Observation",
        "category" : [ {
          "coding" : [ {
            "system" : "http://terminology.hl7.org/CodeSystem/observation-category",
            "code" : "exam",
            "display" : "Exam"
          } ]
        } ],
        "code" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "88020-3",
            "display" : "Functional capacity NYHA",
            "@sliceName" : "loincCode"
          } ]
        },
        "effectiveDateTime" : "{{effectivedate.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss' | 'yyyy-MM-dd')}}",
        "valueCodeableConcept" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "{{mpp:getConcept(%nyhaConceptMap, NYHA_class, 'target_code')}}",
            "display" : "{{mpp:getConcept(%nyhaConceptMap, NYHA_class, 'target_display')}}"
          } ]
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', studyId_0919.toString())}}",
        "encounter" : "{{? mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounter.hospitalization_ID)}}",
        "identifier" : [ {
          "value" : "{{studyId_0919.toString() & '-' & NYHA_class & '-' & effectivedate.toString()}}"
        } ],
        "status" : "final"
      }
    }
  } ]
}