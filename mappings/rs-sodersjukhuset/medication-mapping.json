{
  "id" : "medication-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/rs-sodersjukhuset/medication-mapping",
  "name" : "medication-mapping",
  "title" : "MedicationOrdination table mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-sodersjukhuset/Medication",
    "joinOn" : [ "subject" ]
  }, {
    "alias" : "encounters",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-sodersjukhuset/Encounter",
    "joinOn" : [ "subject" ]
  } ],
  "context" : { },
  "variable" : [ {
    "name" : "effectiveDate",
    "language" : "text/fhirpath",
    "expression" : "date.substring(0, 10).utl:toFhirDateTime('yyyy-MM-dd')"
  }, {
    "name" : "relatedEncounter",
    "language" : "text/fhirpath",
    "expression" : " %encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate)).first() "
  }, {
    "name" : "relatedEncounterSecondary",
    "language" : "text/fhirpath",
    "expression" : " iif(%relatedEncounter.empty(), %encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate))).first()  "
  } ],
  "mapping" : [ {
    "precondition" : {
      "name" : "dateExists",
      "language" : "text/fhirpath",
      "expression" : "date.exists()"
    },
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('MedicationRequest', identifier)}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-MedicationRequest" ]
        },
        "resourceType" : "MedicationRequest",
        "medication" : {
          "concept" : {
            "coding" : [ {
              "system" : "http://www.whocc.no/atc",
              "code" : "{{medication}}",
              "@sliceName" : "atcCode"
            } ]
          }
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', subject.toString())}}",
        "encounter" : "{{? iif(%relatedEncounter.exists(), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounter.id), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounterSecondary.id) )}}",
        "identifier" : [ {
          "value" : "{{identifier}}"
        } ],
        "status" : "completed",
        "intent" : "{{intent}}",
        "effectiveDosePeriod" : {
          "start" : "{{date.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss' | 'yyyy-MM-dd')}}"
        },
        "dosageInstruction" : [ {
          "text" : "{{(iif(dosage.exists(), 'Dosage: ' & dosage.toString()) | iif(dosageStrength.exists(), 'Strength: ' & dosageStrength.toString()) | iif(dosageUnit.exists(), 'Unit: ' & dosageUnit)).utl:mkString(' | ')}}",
          "doseAndRate" : [ {
            "doseQuantity" : {
              "value" : "{{? dosage}}"
            }
          } ]
        } ]
      }
    }
  } ]
}