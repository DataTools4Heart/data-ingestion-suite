{
  "id" : "vital-sign-mapping",
  "url" : "https://datatools4heart.eu/fhir/mappings/rs-sodersjukhuset/vital-sign-mapping",
  "name" : "vital-sign-mapping",
  "title" : "VitalSign table mapping",
  "isDraft" : false,
  "source" : [ {
    "alias" : "source",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-sodersjukhuset/VitalSign",
    "joinOn" : [ "subject" ]
  }, {
    "alias" : "encounters",
    "url" : "https://datatools4heart.eu/fhir/schemas/rs-sodersjukhuset/Encounter",
    "joinOn" : [ "subject" ]
  } ],
  "context" : {
    "vitalSignUnits" : {
      "category" : "concept-map",
      "url" : "$CONTEXT_REPO/rs-sodersjukhuset/vital-sign-units.csv"
    }
  },
  "variable" : [ {
    "name" : "effectiveDate",
    "language" : "text/fhirpath",
    "expression" : "effectiveDateTime.substring(0, 10).utl:toFhirDateTime('yyyy-MM-dd')"
  }, {
    "name" : "relatedEncounter",
    "language" : "text/fhirpath",
    "expression" : " %encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(position = 'primary').where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate)).first() "
  }, {
    "name" : "relatedEncounterSecondary",
    "language" : "text/fhirpath",
    "expression" : " iif(%relatedEncounter.empty(), %encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') <= %effectiveDate and dischargeDate.utl:toFhirDateTime('yyyy-MM-dd') >= %effectiveDate).nav:orElse(%encounters.where(admissionDate.utl:toFhirDateTime('yyyy-MM-dd') = %effectiveDate))).first()  "
  } ],
  "mapping" : [ {
    "description" : "Filtering out extreme values:\nWeight > 300\nHeight > 300\nSPO2 > 100",
    "precondition" : {
      "name" : "filterOutExtremeValues",
      "language" : "text/fhirpath",
      "expression" : "(code = '8302-2' and value < 300) or (code = '29463-7' and value < 300) or (code = '2708-6' and value < 100) or (code != '8302-2' and code != '29463-7' and code != '2708-6')"
    },
    "expression" : {
      "name" : "result",
      "language" : "application/fhir-template+json",
      "value" : {
        "id" : "{{mpp:getHashedId('Observation', identifier)}}",
        "meta" : {
          "profile" : [ "https://datatools4heart.eu/fhir/StructureDefinition/HFR-VitalSign" ]
        },
        "resourceType" : "Observation",
        "category" : [ {
          "coding" : [ {
            "system" : "http://terminology.hl7.org/CodeSystem/observation-category",
            "code" : "vital-signs",
            "display" : "Vital Signs"
          } ]
        } ],
        "code" : {
          "coding" : [ {
            "system" : "http://loinc.org",
            "code" : "{{code}}",
            "@sliceName" : "loincCode"
          } ]
        },
        "effectiveDateTime" : "{{effectiveDateTime.utl:toFhirDateTime('yyyy-MM-dd HH:mm:ss' | 'yyyy-MM-dd')}}",
        "valueQuantity" : {
          "system" : "http://unitsofmeasure.org",
          "code" : "{{mpp:getConcept(%vitalSignUnits, code, 'unit')}}",
          "value" : "{{value}}",
          "unit" : "{{mpp:getConcept(%vitalSignUnits, code, 'unit')}}"
        },
        "subject" : "{{mpp:createFhirReferenceWithHashedId('Patient', subject.toString())}}",
        "encounter" : "{{? iif(%relatedEncounter.exists(), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounter.id), mpp:createFhirReferenceWithHashedId('Encounter', %relatedEncounterSecondary.id) )}}",
        "identifier" : [ {
          "value" : "{{identifier}}"
        } ],
        "status" : "final"
      }
    }
  } ]
}